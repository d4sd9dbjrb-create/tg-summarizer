# --- Telegram API (получи на https://my.telegram.org) ---
TG_API_ID=123456
TG_API_HASH=your_api_hash

# --- Управляющий бот (создай у @BotFather) ---
CONTROL_BOT_TOKEN=123:abc
# Username бота БЕЗ @. Используется в deep-link для связки веб->бот
CONTROL_BOT_USERNAME=your_bot_name
# Твой Telegram user_id (узнай у @userinfobot). Админ сервиса.
ADMIN_USER_ID=0

# --- Бета-доступ ---
# Один invite-код на всех (ввод на сайте при регистрации)
INVITE_CODE=changeme-beta-2026

# --- Безопасность ---
# Fernet-ключ для шифрования Telegram-сессий в БД.
# Сгенерируй: python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
SESSION_ENCRYPTION_KEY=
# Секрет для подписи cookie веб-сессий (любая случайная строка >= 32 символа)
WEB_SECRET_KEY=change-me-to-something-very-long-random

# --- LLM ---
# Провайдер: deepseek | gemini
LLM_PROVIDER=deepseek
DEEPSEEK_API_KEY=
DEEPSEEK_MODEL=deepseek-chat
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# --- БД ---
POSTGRES_USER=tg
POSTGRES_PASSWORD=tg
POSTGRES_DB=tg
POSTGRES_HOST=db
POSTGRES_PORT=5432

# --- Web (регистрация) ---
WEB_HOST=0.0.0.0
WEB_PORT=8000
# Публичный URL сайта (для генерации ссылок и deep-link). Локально — http://localhost:8000
PUBLIC_BASE_URL=http://localhost:8000

# --- Production (только при деплое через docker-compose.prod.yml + Caddy) ---
# Домен, на который указывает A-запись твоего VPS. Caddy автоматически получит SSL.
DOMAIN=example.com

# --- Поведение ---
TIMEZONE=Europe/Moscow
DAILY_DIGEST_HOUR=9
# По умолчанию какие чаты учитывать у нового юзера: all | whitelist
INGEST_MODE=all
# Сколько дней хранить сообщения (0 = бесконечно)
MESSAGE_RETENTION_DAYS=90
